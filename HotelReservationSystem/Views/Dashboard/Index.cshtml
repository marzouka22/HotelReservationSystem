<div class="container mt-4">

	<h2>Admin Dashboard</h2>

	<div class="row">

		<div class="col-md-4">
			<div class="card bg-primary text-white p-3">
				<h3>@ViewBag.Rooms</h3>
				<p>Total Rooms</p>
			</div>
		</div>

		<div class="col-md-4">
			<div class="card bg-success text-white p-3">
				<h3>@ViewBag.Clients</h3>
				<p>Total Clients</p>
			</div>
		</div>

		<div class="col-md-4">
			<div class="card bg-warning text-white p-3">
				<h3>@ViewBag.Reservations</h3>
				<p>Total Reservations</p>
			</div>
		</div>

	</div>
</div>
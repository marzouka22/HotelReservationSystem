@model HotelReservationSystem.Models.Reservation

@{
    ViewData["Title"] = "Supprimer la réservation";
}

<h1 class="mb-3">Supprimer la réservation</h1>

<div class="alert alert-danger">
    Êtes-vous sûr de vouloir supprimer cette réservation ? Cette action est irréversible.
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Arrivée</dt>
            <dd class="col-sm-9">@Model.CheckIn.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">Départ</dt>
            <dd class="col-sm-9">@Model.CheckOut.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-3">Chambre</dt>
            <dd class="col-sm-9">@(Model.Room?.RoomNumber ?? "-")</dd>

            <dt class="col-sm-3">Client</dt>
            <dd class="col-sm-9">
                @if (Model.Client != null)
                {
                    @Model.Client.FullName
                }
                else if (!string.IsNullOrEmpty(Model.UserId))
                {
                    <span>@(Model.User?.Email ?? "Utilisateur inscrit")</span>
                }
                else
                {
                    <span class="text-muted">-</span>
                }
            </dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Supprimer définitivement</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
</form>

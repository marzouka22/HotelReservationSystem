@model HotelReservationSystem.Models.Reservation

@{
    ViewData["Title"] = "Modifier la réservation";
}

<h1 class="mb-3">Modifier la réservation</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post" class="card card-body shadow-sm">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger mb-2"></div>
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="CheckIn" class="form-label">Arrivée</label>
                <input asp-for="CheckIn" type="date" class="form-control" />
                <span asp-validation-for="CheckIn" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CheckOut" class="form-label">Départ</label>
                <input asp-for="CheckOut" type="date" class="form-control" />
                <span asp-validation-for="CheckOut" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="RoomId" class="form-label">Chambre</label>
                <select asp-for="RoomId" class="form-select" asp-items="ViewBag.RoomId">
                    <option value="">-- Sélectionner --</option>
                </select>
                <span asp-validation-for="RoomId" class="text-danger"></span>
            </div>

            @if (User.IsInRole("Admin"))
            {
                <div class="mb-3">
                    <label asp-for="ClientId" class="form-label">Client</label>
                    <select asp-for="ClientId" class="form-select" asp-items="ViewBag.ClientId">
                        <option value="">-- Aucun --</option>
                    </select>
                    <span asp-validation-for="ClientId" class="text-danger"></span>
                </div>
            }

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Enregistrer</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}

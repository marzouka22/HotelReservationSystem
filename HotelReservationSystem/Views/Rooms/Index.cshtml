@model IEnumerable<HotelReservationSystem.Models.Room>
@using HotelReservationSystem.Models

@{
    ViewData["Title"] = "Chambres";
    var types = (ViewBag.Types as IEnumerable<string>) ?? Enumerable.Empty<string>();
    var currentType = ViewBag.CurrentType as string;
    var minPrice = ViewBag.MinPrice as decimal?;
    var maxPrice = ViewBag.MaxPrice as decimal?;
    var onlyAvailable = ViewBag.OnlyAvailable as bool? ?? false;
    var checkIn = ViewBag.CheckIn as DateTime?;
    var checkOut = ViewBag.CheckOut as DateTime?;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Chambres</h1>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-success">+ Ajouter une chambre</a>
    }
</div>

<form method="get" asp-action="Index" class="card card-body mb-4 shadow-sm">
    <div class="row g-2 align-items-end">
        <div class="col-md-2">
            <label class="form-label small">Type</label>
            <select name="type" class="form-select">
                <option value="">Tous</option>
                @foreach (var t in types)
                {
                    if (currentType == t)
                    {
                        <option value="@t" selected>@t</option>
                    }
                    else
                    {
                        <option value="@t">@t</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small">Prix min (€)</label>
            <input name="minPrice" type="number" step="0.01" min="0" class="form-control" value="@(minPrice?.ToString("0.##"))" />
        </div>
        <div class="col-md-2">
            <label class="form-label small">Prix max (€)</label>
            <input name="maxPrice" type="number" step="0.01" min="0" class="form-control" value="@(maxPrice?.ToString("0.##"))" />
        </div>
        <div class="col-md-2">
            <label class="form-label small">Arrivée</label>
            <input name="checkIn" type="date" class="form-control" value="@(checkIn?.ToString("yyyy-MM-dd"))" />
        </div>
        <div class="col-md-2">
            <label class="form-label small">Départ</label>
            <input name="checkOut" type="date" class="form-control" value="@(checkOut?.ToString("yyyy-MM-dd"))" />
        </div>
        <div class="col-md-2 d-flex flex-column">
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" name="onlyAvailable" value="true" id="onlyAvailable" @(onlyAvailable ? "checked" : "") />
                <label class="form-check-label small" for="onlyAvailable">Disponibles seulement</label>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-primary flex-grow-1">Filtrer</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
            </div>
        </div>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-warning">Aucune chambre ne correspond à votre recherche.</div>
}
else
{
    <div class="row g-3">
        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between">
                            <h5 class="card-title mb-1">Chambre @item.RoomNumber</h5>
                            @if (item.Status == RoomStatus.Available)
                            {
                                <span class="badge bg-success">Disponible</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">En maintenance</span>
                            }
                        </div>
                        <p class="text-muted small mb-1">@item.Type · @item.Capacity personne(s)</p>
                        <p class="h4 text-primary mb-3">@item.Price.ToString("0.00") €</p>
                        <div class="mt-auto d-flex flex-wrap gap-2">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Détails</a>
                            @if ((User.Identity?.IsAuthenticated ?? false) && item.Status == RoomStatus.Available)
                            {
                                <a asp-controller="Reservations" asp-action="Create"
                                   asp-route-checkIn="@(checkIn?.ToString("yyyy-MM-dd"))"
                                   asp-route-checkOut="@(checkOut?.ToString("yyyy-MM-dd"))"
                                   class="btn btn-sm btn-success">Réserver</a>
                            }
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Modifier</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Supprimer</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@model HotelReservationSystem.Models.Room
@using HotelReservationSystem.Models

@{
    ViewData["Title"] = "Supprimer la chambre";
}

<h1 class="mb-3">Supprimer la chambre</h1>

<div class="alert alert-danger">
    Êtes-vous sûr de vouloir supprimer cette chambre ? Cette action est irréversible.
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Numéro</dt>
            <dd class="col-sm-9">@Model.RoomNumber</dd>

            <dt class="col-sm-3">Type</dt>
            <dd class="col-sm-9">@Model.Type</dd>

            <dt class="col-sm-3">Prix</dt>
            <dd class="col-sm-9">@Model.Price.ToString("0.00") €</dd>

            <dt class="col-sm-3">Capacité</dt>
            <dd class="col-sm-9">@Model.Capacity personne(s)</dd>

            <dt class="col-sm-3">Statut</dt>
            <dd class="col-sm-9">@(Model.Status == RoomStatus.Available ? "Disponible" : "En maintenance")</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Supprimer définitivement</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
</form>
